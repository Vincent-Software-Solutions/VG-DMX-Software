{
  "name": "vg-dmx-software",
  "version": "1.0.0",
  "description": "VG | DMX Software - Lichtsteuerung (Daslight-Style) fuer DSD TECH USB-DMX",
  "author": "Martin (VG)",
  "homepage": "https://github.com/Vincent-Software-Solutions",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "release": "electron-vite build && electron-builder --linux --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  },
  "build": {
    "appId": "com.vg.dmxsoftware",
    "productName": "VG DMX Software",
    "artifactName": "${name}-${version}.${ext}",
    "directories": { "output": "dist", "buildResources": "build" },
    "files": ["out/**/*", "package.json"],
    "asarUnpack": ["**/node_modules/serialport/**", "**/node_modules/@serialport/**"],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "AudioVideo",
      "maintainer": "VG"
    },
    "win": { "target": ["nsis"] },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true },
    "mac": { "target": ["dmg"], "category": "public.app-category.music" },
    "publish": [{ "provider": "github", "owner": "Vincent-Software-Solutions", "repo": "VG-DMX-Software" }]
  }
}
